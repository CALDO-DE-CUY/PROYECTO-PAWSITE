<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil - PawSite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        latte: {
                            50: '#FDFBF7',  
                            100: '#F4EFE6', 
                            200: '#E6DCC8', 
                        },
                        cafe: {
                            600: '#A07855', 
                            700: '#8A5A36', 
                            800: '#51331E', 
                            900: '#362214', 
                        }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-latte-50 font-sans min-h-screen flex flex-col justify-between text-stone-800">

    <!-- BARRA DE NAVEGACIÓN -->
    <nav class="bg-white/80 backdrop-blur-md border-b border-latte-100 px-6 py-3 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <!-- Logo -->
            <a href="ini.html" class="flex items-center gap-2.5 group">
                <div class="w-9 h-9 bg-amber-100 text-cafe-700 rounded-xl flex items-center justify-center text-base shadow-sm group-hover:bg-cafe-800 group-hover:text-white transition-all duration-300">
                    <i class="fa-solid fa-paw"></i>
                </div>
                <span class="text-lg font-bold text-cafe-900 tracking-tight">Paw<span class="text-cafe-600 font-medium">Site</span></span>
            </a>
            
            <a href="Adoptante.html" class="text-xs font-semibold text-cafe-800 hover:text-cafe-900 transition-colors flex items-center gap-1">
                Ver Catálogo
            </a>
        </div>
    </nav>

    <!-- CONTENIDO DEL PERFIL -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-10 relative">
        
        <!-- CONTENEDOR DIFUMINADO (SIMULA EL PERFIL OCULTO) -->
        <div class="blur-[2px] pointer-events-none select-none opacity-40 space-y-8 transition-all">
            
            <!-- Encabezado del Perfil Oculto -->
            <div class="bg-white p-6 rounded-3xl border border-stone-200 shadow-sm flex flex-col sm:flex-row items-center gap-5">
                <!-- Avatar Vacío -->
                <div class="w-20 h-20 bg-stone-200 rounded-full flex items-center justify-center text-stone-400 text-3xl">
                    <i class="fa-solid fa-user"></i>
                </div>
                <!-- Datos de Relleno Ocultos -->
                <div class="space-y-2 flex-1 w-full text-center sm:text-left">
                    <div class="h-6 bg-stone-300 rounded-md w-48 mx-auto sm:mx-0 animate-pulse"></div>
                    <div class="h-4 bg-stone-200 rounded-md w-32 mx-auto sm:mx-0 animate-pulse"></div>
                </div>
                <div class="w-24 h-8 bg-stone-200 rounded-xl animate-pulse"></div>
            </div>

            <!-- Bloques de contenido simulado -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white p-5 rounded-2xl border border-stone-200 space-y-3 shadow-sm">
                    <div class="w-8 h-8 bg-stone-200 rounded-lg animate-pulse"></div>
                    <div class="h-4 bg-stone-300 rounded w-3/4 animate-pulse"></div>
                    <div class="h-3 bg-stone-200 rounded w-full animate-pulse"></div>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-stone-200 space-y-3 shadow-sm">
                    <div class="w-8 h-8 bg-stone-200 rounded-lg animate-pulse"></div>
                    <div class="h-4 bg-stone-300 rounded w-1/2 animate-pulse"></div>
                    <div class="h-3 bg-stone-200 rounded w-full animate-pulse"></div>
                </div>
                <div class="bg-white p-5 rounded-2xl border border-stone-200 space-y-3 shadow-sm">
                    <div class="w-8 h-8 bg-stone-200 rounded-lg animate-pulse"></div>
                    <div class="h-4 bg-stone-300 rounded w-2/3 animate-pulse"></div>
                    <div class="h-3 bg-stone-200 rounded w-full animate-pulse"></div>
                </div>
            </div>
        </div>

        <!-- TARJETA FLOTANTE DE INVITACIÓN (CTA superpuesto en el centro) -->
        <div class="absolute inset-0 flex items-center justify-center px-6">
            <div class="bg-white p-8 md:p-10 rounded-3xl border border-amber-200/60 shadow-2xl max-w-md w-full text-center space-y-6 transform scale-100 hover:scale-[1.01] transition-all duration-300 backdrop-blur-sm bg-white/95">
                
                <!-- Icono Emblema -->
                <div class="w-16 h-16 bg-amber-50 text-cafe-700 rounded-2xl flex items-center justify-center text-2xl mx-auto border border-amber-200/50 shadow-sm animate-bounce">
                    <i class="fa-solid fa-heart-circle-plus"></i>
                </div>

                <!-- Textos -->
                <div class="space-y-2">
                    <h2 class="text-2xl font-black text-cafe-900 tracking-tight">¡Únete a Paw Site!</h2>
                    <p class="text-stone-600 text-sm leading-relaxed">
                        Crea tu perfil para seguir solicitudes de adopción o registrarte como rescatista oficial.
                    </p>
                </div>

                <!-- Botones de Acción -->
                <div class="space-y-3 pt-2">
                    <!-- Redirige a tu página de login/registro -->
                    <a href="Pagina de Inicio Adoptante.html" class="block w-full bg-cafe-800 hover:bg-cafe-900 text-white font-semibold py-3 rounded-xl transition-all duration-300 text-sm shadow-md shadow-cafe-900/10">
                        Registrarme / Iniciar Sesión
                    </a>
                    
                    <a href="Adoptante.html" class="block w-full text-xs font-medium text-stone-500 hover:text-cafe-700 transition-colors py-1">
                        Seguir explorando como invitado
                    </a>
                </div>
            </div>
        </div>

    </main>

    <!-- PIE DE PÁGINA -->
    <footer class="bg-white border-t border-latte-100 py-4 text-center text-xs text-stone-500 w-full">
        <p>&copy; 2026 PAW SITE. Hecho con <i class="fa-solid fa-heart text-amber-600"></i> para los animales.</p>
    </footer>

</body>
</html>
